# Evidence To PPT Workflow example environment.
# Do not commit real API keys. Copy this file to .env for local use.

# Search / Retriever
RETRIEVER=tavily
TAVILY_API_KEY=
BRAVE_API_KEY=

# LLM provider profile example: DeepSeek
# This is an example profile, not a project requirement.
# Replace these values with any GPT Researcher-supported provider if preferred.
DEEPSEEK_API_KEY=
FAST_LLM=deepseek:deepseek-chat
SMART_LLM=deepseek:deepseek-chat
STRATEGIC_LLM=deepseek:deepseek-chat

# Alternative profile example: OpenAI
# OPENAI_API_KEY=
# FAST_LLM=openai:gpt-4o-mini
# SMART_LLM=openai:gpt-4.1
# STRATEGIC_LLM=openai:o4-mini

# Alternative profile example: Google Gemini
# GOOGLE_API_KEY=
# FAST_LLM=google_genai:gemini-1.5-flash
# SMART_LLM=google_genai:gemini-1.5-pro
# STRATEGIC_LLM=google_genai:gemini-1.5-pro

# Embedding
# Choose a GPT Researcher-supported embedding provider.
EMBEDDING=ollama:nomic-embed-text
OLLAMA_BASE_URL=http://localhost:11434

# Alternative embedding examples:
# EMBEDDING=openai:text-embedding-3-small
# EMBEDDING=google_genai:models/text-embedding-004

# GPT Researcher workflow defaults
REPORT_SOURCE=web
REPORT_FORMAT=APA
MAX_ITERATIONS=3
MAX_SEARCH_RESULTS_PER_QUERY=5
TOTAL_WORDS=1800
CURATE_SOURCES=True
